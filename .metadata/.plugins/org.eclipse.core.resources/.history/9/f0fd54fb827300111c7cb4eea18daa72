public class Demo1 
{
	public static int reverse(int num)
	{
		int temp=num;
		int rev =0;
		while(temp!=0)
		{
			int ld = temp%10;
			rev=(rev*10)+ld;
			temp/=10;
		}
		return rev;
		
	}
	public static void main(String[] args) {
		Progarms p= new Progarms();
		//p.prog1();
